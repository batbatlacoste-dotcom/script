    faceIcon.Size = UDim2.new(0, 24, 0, 24)
    faceIcon.Position = UDim2.new(0, 8, 0.5, -12)
    faceIcon.BackgroundTransparency = 1
    faceIcon.Image = "rbxassetid://134637731"
    faceIcon.Parent = topBar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Size = UDim2.new(0, 200, 1, 0)
    titleLabel.Position = UDim2.new(0, 40, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.Text = "universal shit"
    titleLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = topBar

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 0, 25)
    closeBtn.Position = UDim2.new(1, -35, 0.5, -12)
    closeBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.Text = "X"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.TextSize = 12
    closeBtn.Parent = topBar
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 4)

    closeBtn.MouseButton1Click:Connect(function()
        screenGui:Destroy()
    end)

    local minMainBtn = Instance.new("TextButton")
    minMainBtn.Size = UDim2.new(0, 30, 0, 25)
    minMainBtn.Position = UDim2.new(1, -70, 0.5, -12)
    minMainBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    minMainBtn.Font = Enum.Font.GothamBold
    minMainBtn.Text = "-"
    minMainBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    minMainBtn.TextSize = 14
    minMainBtn.Parent = topBar
    Instance.new("UICorner", minMainBtn).CornerRadius = UDim.new(0, 4)

    local mainMinimized = false
    minMainBtn.MouseButton1Click:Connect(function()
        mainMinimized = not mainMinimized
        for _, child in ipairs(mainFrame:GetChildren()) do
            if child ~= topBar and child ~= mainCorner and child ~= rgbStroke then
                child.Visible = not mainMinimized
            end
        end
        mainFrame.Size = mainMinimized and UDim2.new(0, 520, 0, 35) or UDim2.new(0, 520, 0, 360)
        minMainBtn.Text = mainMinimized and "+" or "-"
    end)

    local tabContainer = Instance.new("ScrollingFrame")
    tabContainer.Size = UDim2.new(0, 130, 1, -45)
    tabContainer.Position = UDim2.new(0, 5, 0, 40)
    tabContainer.BackgroundTransparency = 1
    tabContainer.BorderSizePixel = 0
    tabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabContainer.ScrollBarThickness = 2
    tabContainer.Parent = mainFrame

    local tabListLayout = Instance.new("UIListLayout")
    tabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabListLayout.Padding = UDim.new(0, 6)
    tabListLayout.Parent = tabContainer

    local contentArea = Instance.new("Frame")
    contentArea.Size = UDim2.new(1, -145, 1, -45)
    contentArea.Position = UDim2.new(0, 140, 0, 40)
    contentArea.BackgroundColor3 = Color3.fromRGB(25, 25, 32)
    contentArea.BorderSizePixel = 0
    contentArea.Parent = mainFrame
    Instance.new("UICorner", contentArea).CornerRadius = UDim.new(0, 6)

    local tabNames = {"random shit", "tab 2", "tab 3"}
    local tabs = {}
    local pages = {}

    for i, name in ipairs(tabNames) do
        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(1, 0, 0, 30)
        tabBtn.BackgroundColor3 = i == 1 and Color3.fromRGB(45, 45, 58) or Color3.fromRGB(30, 30, 38)
        tabBtn.BorderSizePixel = 0
        tabBtn.Font = Enum.Font.GothamSemibold
        tabBtn.Text = name
        tabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
        tabBtn.TextSize = 12
        tabBtn.Parent = tabContainer
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 4)
        
        local page = Instance.new("ScrollingFrame")
        page.Size = UDim2.new(1, -10, 1, -10)
        page.Position = UDim2.new(0, 5, 0, 5)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.Visible = (i == 1)
        page.CanvasSize = UDim2.new(0, 0, 0, 100)
        page.ScrollBarThickness = 4
        page.Parent = contentArea
        
        local pageLayout = Instance.new("UIListLayout")
        pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        pageLayout.Padding = UDim.new(0, 8)
        pageLayout.Parent = page
        
        tabs[i] = tabBtn
        pages[i] = page
        
        tabBtn.MouseButton1Click:Connect(function()
            for j, p in ipairs(pages) do
                p.Visible = (j == i)
                tabs[j].BackgroundColor3 = (j == i) and Color3.fromRGB(45, 45, 58) or Color3.fromRGB(30, 30, 38)
                tabs[j].TextColor3 = (j == i) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
            end
        end)
    end

    local randomShitPage = pages[1]
    local flying = false
    local flightSpeed = 50
    local flightKey = Enum.KeyCode.E
    local keysPressed = { W = false, A = false, S = false, D = false, Space = false, Control = false }
    local camera = workspace.CurrentCamera

    local flySection = Instance.new("Frame")
    flySection.Size = UDim2.new(1, -10, 0, 160)
    flySection.BackgroundColor3 = Color3.fromRGB(32, 32, 42)
    flySection.BorderSizePixel = 0
    flySection.Parent = randomShitPage
    Instance.new("UICorner", flySection).CornerRadius = UDim.new(0, 6)

    local flyTitle = Instance.new("TextLabel")
    flyTitle.Size = UDim2.new(1, -10, 0, 30)
    flyTitle.Position = UDim2.new(0, 10, 0, 5)
    flyTitle.BackgroundTransparency = 1
    flyTitle.Font = Enum.Font.GothamBold
    flyTitle.Text = "Fly Controller"
    flyTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    flyTitle.TextSize = 13
    flyTitle.TextXAlignment = Enum.TextXAlignment.Left
    flyTitle.Parent = flySection

    local toggleFlyBtn = Instance.new("TextButton")
    toggleFlyBtn.Size = UDim2.new(0, 140, 0, 28)
    toggleFlyBtn.Position = UDim2.new(0, 10, 0, 40)
    toggleFlyBtn.BackgroundColor3 = Color3.fromRGB(50, 120, 80)
    toggleFlyBtn.Font = Enum.Font.GothamBold
    toggleFlyBtn.Text = "Toggle Fly [OFF]"
    toggleFlyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleFlyBtn.TextSize = 11
    toggleFlyBtn.Parent = flySection
    Instance.new("UICorner", toggleFlyBtn).CornerRadius = UDim.new(0, 4)

    local speedLabel = Instance.new("TextLabel")
    speedLabel.Size = UDim2.new(0, 120, 0, 25)
    speedLabel.Position = UDim2.new(0, 10, 0, 78)
    speedLabel.BackgroundTransparency = 1
    speedLabel.Font = Enum.Font.Gotham
    speedLabel.Text = "Speed: 50"
    speedLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    speedLabel.TextSize = 12
    speedLabel.TextXAlignment = Enum.TextXAlignment.Left
    speedLabel.Parent = flySection

    local speedBox = Instance.new("TextBox")
    speedBox.Size = UDim2.new(0, 100, 0, 28)
    speedBox.Position = UDim2.new(0, 130, 0, 76)
    speedBox.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    speedBox.Font = Enum.Font.Gotham
    speedBox.PlaceholderText = "Enter speed..."
    speedBox.Text = "50"
    speedBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedBox.TextSize = 12
    speedBox.Parent = flySection
    Instance.new("UICorner", speedBox).CornerRadius = UDim.new(0, 4)

    speedBox.FocusLost.Connect(function(enterPressed)
        if enterPressed then
            local newSpeed = tonumber(speedBox.Text)
            if newSpeed then
                flightSpeed = newSpeed
                speedLabel.Text = "Speed: " .. tostring(flightSpeed)
            else
                speedBox.Text = tostring(flightSpeed)
            end
        end
    end)

    local keybindLabel = Instance.new("TextLabel")
    keybindLabel.Size = UDim2.new(0, 140, 0, 25)
    keybindLabel.Position = UDim2.new(0, 10, 0, 115)
    keybindLabel.BackgroundTransparency = 1
    keybindLabel.Font = Enum.Font.Gotham
    keybindLabel.Text = "Keybind: [ E ]"
    keybindLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    keybindLabel.TextSize = 12
    keybindLabel.TextXAlignment = Enum.TextXAlignment.Left
    keybindLabel.Parent = flySection

    local changeKeyBtn = Instance.new("TextButton")
    changeKeyBtn.Size = UDim2.new(0, 100, 0, 28)
    changeKeyBtn.Position = UDim2.new(0, 130, 0, 113)
    changeKeyBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    changeKeyBtn.Font = Enum.Font.GothamBold
    changeKeyBtn.Text = "Change Key"
    changeKeyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    changeKeyBtn.TextSize = 11
    changeKeyBtn.Parent = flySection
    Instance.new("UICorner", changeKeyBtn).CornerRadius = UDim.new(0, 4)

    local bindingKey = false
    changeKeyBtn.MouseButton1Click:Connect(function()
        bindingKey = true
        changeKeyBtn.Text = "Press Key..."
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if bindingKey and input.UserInputType == Enum.UserInputType.Keyboard then
            flightKey = input.KeyCode
            keybindLabel.Text = "Keybind: [ " .. flightKey.Name .. " ]"
            changeKeyBtn.Text = "Change Key"
            bindingKey = false
            return
        end
        
        if gameProcessed then return end
        
        if input.KeyCode == flightKey then
            flying = not flying
            toggleFlyBtn.Text = flying and "Toggle Fly [ON]" or "Toggle Fly [OFF]"
            toggleFlyBtn.BackgroundColor3 = flying and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(50, 120, 80)
            
            local character = player.Character
            if character and character:FindFirstChild("Humanoid") then
                character.Humanoid.PlatformStand = flying
                if not flying then
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        if hrp:FindFirstChild("BodyVelocity") then hrp.BodyVelocity:Destroy() end
                        if hrp:FindFirstChild("BodyGyro") then hrp.BodyGyro:Destroy() end
                    end
                end
            end
        end
        
        if keysPressed[input.KeyCode.Name] ~= nil then
            keysPressed[input.KeyCode.Name] = true
        end
    end)

    toggleFlyBtn.MouseButton1Click:Connect(function()
        flying = not flying
        toggleFlyBtn.Text = flying and "Toggle Fly [ON]" or "Toggle Fly [OFF]"
        toggleFlyBtn.BackgroundColor3 = flying and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(50, 120, 80)
        
        local character = player.Character
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid.PlatformStand = flying
            if not flying then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if hrp:FindFirstChild("BodyVelocity") then hrp.BodyVelocity:Destroy() end
                    if hrp:FindFirstChild("BodyGyro") then hrp.BodyGyro:Destroy() end
                end
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if keysPressed[input.KeyCode.Name] ~= nil then
            keysPressed[input.KeyCode.Name] = false
        end
    end)

    RunService.RenderStepped:Connect(function(dt)
        local hue = tick() % 5 / 5
        rgbStroke.Color = Color3.fromHSV(hue, 1, 1)
        faceIcon.Rotation = (faceIcon.Rotation + dt * 100) % 360
        
        if not flying then return end
        
        local character = player.Character
        if not character then return end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local bodyVelocity = hrp:FindFirstChild("BodyVelocity")
        if not bodyVelocity then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Parent = hrp
        end
        
        local bodyGyro = hrp:FindFirstChild("BodyGyro")
        if not bodyGyro then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.P = 30000
            bodyGyro.Parent = hrp
        end
        
        local cam = workspace.CurrentCamera
        local moveDir = Vector3.new()
        local lookVec = cam.CFrame.LookVector
        local rightVec = cam.CFrame.RightVector
        
        if keysPressed.W then moveDir = moveDir + lookVec end
        if keysPressed.S then moveDir = moveDir - lookVec end
        if keysPressed.A then moveDir = moveDir - rightVec end
        if keysPressed.D then moveDir = moveDir + rightVec end
        if keysPressed.Space then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if keysPressed.Control then moveDir = moveDir - Vector3.new(0, 1, 0) end
        
        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * flightSpeed
        end
        
        bodyVelocity.Velocity = moveDir
        bodyGyro.CFrame = cam.CFrame
    end)

    local dragging, dragInput, dragStart, startPos
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
        end
    end)
    topBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end)
